{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema.json",
  "productName": "UMMS",
  "version": "0.1.0",
  "identifier": "com.umms.desktop",
  "build": {
    "frontendDist": "../dashboard/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../dashboard && npm run dev",
    "beforeBuildCommand": "cd ../dashboard && npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "UMMS — Universal Memory System",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
